# browserhand configuration (all via environment variables)

# HTTP port the service listens on (binds 0.0.0.0). OSC injects this.
PORT=8080

# Optional bearer token. If set, all /v1 requests must send:
#   Authorization: Bearer <token>
# Leave unset to run open (e.g. inside a trusted network).
BROWSERHAND_API_KEY=

# Maximum number of concurrent browser sessions. New sessions beyond this
# are rejected with 429 until capacity frees up.
MAX_CONCURRENT_SESSIONS=5

# Idle timeout (ms). A session with no activity for this long is auto-closed.
SESSION_TIMEOUT_MS=300000

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Internal Chromium remote-debugging port used to back the CDP WebSocket proxy
# (/v1/connect/:id). Not exposed publicly; keep the default unless it clashes.
CDP_PORT=9223
