{
  "description": "Deterministic, offline evaluation of how reliably an agent-style caller can operate the web through the browserhand API. Each task is a sequence of API steps over a local fixture with a programmatic success check. No network, no API keys.",
  "tasks": [
    { "id": "nav-title", "fixture": "login.html", "goal": "Navigate and read the page title", "steps": [ { "op": "navigate", "fixture": "login.html" }, { "op": "snapshot" } ], "expect": { "kind": "titleEquals", "value": "Sign in" } },
    { "id": "snapshot-has-refs", "fixture": "login.html", "goal": "Snapshot yields addressable refs", "steps": [ { "op": "navigate", "fixture": "login.html" }, { "op": "snapshot" } ], "expect": { "kind": "minNodes", "value": 3 } },
    { "id": "login-type-click", "fixture": "login.html", "goal": "Type a username and submit to reveal a welcome", "steps": [ { "op": "navigate", "fixture": "login.html" }, { "op": "snapshot" }, { "op": "type", "role": "textbox", "name": "Username", "text": "jonas" }, { "op": "click", "role": "button" } ], "expect": { "kind": "contentContains", "value": "Welcome, jonas" } },
    { "id": "login-denied", "fixture": "login.html", "goal": "Wrong username is denied", "steps": [ { "op": "navigate", "fixture": "login.html" }, { "op": "snapshot" }, { "op": "type", "role": "textbox", "name": "Username", "text": "eve" }, { "op": "click", "role": "button" } ], "expect": { "kind": "contentContains", "value": "Access denied" } },
    { "id": "select-option", "fixture": "catalog.html", "goal": "Select a dropdown option by ref", "steps": [ { "op": "navigate", "fixture": "catalog.html" }, { "op": "snapshot" }, { "op": "select", "role": "combobox", "values": ["b"] } ], "expect": { "kind": "contentContains", "value": "Category: Bananas" } },
    { "id": "read-catalog", "fixture": "catalog.html", "goal": "Read structured content from the page", "steps": [ { "op": "navigate", "fixture": "catalog.html" }, { "op": "content" } ], "expect": { "kind": "contentContains", "value": "Total items: 3" } },
    { "id": "screenshot-png", "fixture": "catalog.html", "goal": "Capture a screenshot the agent can see", "steps": [ { "op": "navigate", "fixture": "catalog.html" }, { "op": "screenshot" } ], "expect": { "kind": "screenshotPng" } },
    { "id": "network-logs", "fixture": "catalog.html", "goal": "Capture network activity for debugging", "steps": [ { "op": "navigate", "fixture": "catalog.html" } ], "expect": { "kind": "minNetworkLogs", "value": 1 } },
    { "id": "download-capture", "fixture": "files.html", "goal": "Capture a downloaded file and read its bytes", "steps": [ { "op": "navigate", "fixture": "files.html" }, { "op": "snapshot" }, { "op": "click", "role": "link" } ], "expect": { "kind": "downloadContains", "value": "browserhand-report-ok" } },
    { "id": "upload-file", "fixture": "files.html", "goal": "Upload a file to a file input", "steps": [ { "op": "navigate", "fixture": "files.html" }, { "op": "snapshot" }, { "op": "upload", "tag": "input", "name": "Attachment", "filename": "note.txt", "text": "hi" } ], "expect": { "kind": "contentContains", "value": "uploaded note.txt" } },
    { "id": "context-reuse", "fixture": "storage.html", "goal": "Reuse cookies/localStorage across sessions", "steps": [ { "op": "navigate", "fixture": "storage.html" }, { "op": "exportContext" }, { "op": "newSessionWithContext" }, { "op": "navigate", "fixture": "storage.html" }, { "op": "content" } ], "expect": { "kind": "tokenReused" } },
    { "id": "stale-ref-error", "fixture": "login.html", "goal": "Unknown ref returns an instructive stale_ref error", "steps": [ { "op": "navigate", "fixture": "login.html" }, { "op": "clickRefExpectError", "ref": "e9999" } ], "expect": { "kind": "errorCode", "value": "stale_ref" } },
    { "id": "missing-session-error", "fixture": "login.html", "goal": "Unknown session returns 404", "steps": [ { "op": "getMissingSession" } ], "expect": { "kind": "statusEquals", "value": 404 } },
    { "id": "bad-request-error", "fixture": "login.html", "goal": "Missing required field returns 400", "steps": [ { "op": "navigateNoUrl" } ], "expect": { "kind": "statusEquals", "value": 400 } },
    { "id": "back-forward", "fixture": "login.html", "goal": "History navigation works", "steps": [ { "op": "navigate", "fixture": "login.html" }, { "op": "navigate", "fixture": "catalog.html" }, { "op": "back" } ], "expect": { "kind": "urlContains", "value": "login.html" } },
    { "id": "reload", "fixture": "catalog.html", "goal": "Reload keeps the same page", "steps": [ { "op": "navigate", "fixture": "catalog.html" }, { "op": "reload" } ], "expect": { "kind": "urlContains", "value": "catalog.html" } },
    { "id": "wait-for-text", "fixture": "catalog.html", "goal": "Wait for visible text to appear", "steps": [ { "op": "navigate", "fixture": "catalog.html" }, { "op": "waitText", "text": "Product Catalog" } ], "expect": { "kind": "ok" } },
    { "id": "screenshot-element", "fixture": "catalog.html", "goal": "Screenshot a single element by ref", "steps": [ { "op": "navigate", "fixture": "catalog.html" }, { "op": "snapshot" }, { "op": "screenshotRef", "role": "combobox" } ], "expect": { "kind": "screenshotPng" } },
    { "id": "console-logs", "fixture": "catalog.html", "goal": "Console log stream is queryable", "steps": [ { "op": "navigate", "fixture": "catalog.html" }, { "op": "consoleLogs" } ], "expect": { "kind": "ok" } },
    { "id": "session-list", "fixture": "login.html", "goal": "Open session appears in the session list", "steps": [ { "op": "navigate", "fixture": "login.html" }, { "op": "listSessions" } ], "expect": { "kind": "sessionListed" } }
  ]
}
